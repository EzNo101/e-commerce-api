# Database
# Local run (without Docker):
DATABASE_URL=postgresql+asyncpg://ecommerce_user:ecommerce@localhost:5432/ecommerce_db
# Docker compose override example (set in docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://ecommerce_user:ecommerce@db:5432/ecommerce_db

# Security
SECRET_KEY=replace_with_secure_random_hex # openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAY=7
ALGORITHM=HS256

# External services (Stripe test keys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Cache
# Local run (without Docker):
REDIS_URL=redis://localhost:6379/0
# Docker compose override example (set in docker-compose.yml):
# REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# Optional
DEBUG=true
